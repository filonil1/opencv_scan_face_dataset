# ==========================================
# Сборка CMake и Бинарники
# ==========================================
build/
bin/
lib/
CMakeUserPresets.json

# Исключаем скомпилированный исполняемый файл в корне (если он там создается)
face_detector

# ==========================================
# Python (Виртуальное окружение для автоматизации)
# ==========================================
.venv/
venv/
ENV/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ==========================================
# Локальная база данных и обученные модели
# ==========================================
# Если ты хочешь хранить саму структуру папок датасета в Git, 
# но не загружать свои личные фотографии и обученную модель:
dataset/model.yml
dataset/manifest.csv
dataset/*/*.jpg
dataset/*/*.png
dataset/*/*.bmp
dataset/*/*.json

# Разрешаем Git отслеживать саму папку dataset, даже если она пустая
!dataset/.gitkeep

# ==========================================
# Редакторы кода и IDE
# ==========================================
# Visual Studio Code
.vscode/
!.vscode/extensions.json
*.code-workspace

# CLion / JetBrains
.idea/
*.iws

# Xcode (если собираешь на macOS через него)
*.xcodeproj/
*.xcworkspace/
DerivedData/
.xcuserstate

# Файлы операционной системы macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# ==========================================
# Временные файлы и логи
# ==========================================
*.log
*.tmp
*.bak